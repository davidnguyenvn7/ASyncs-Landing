# Production env for docker-compose.prod.yml.
# Copy to .env.prod (git-ignored) and set a STRONG password.
#
#   cp .env.prod.example .env.prod
#   # edit POSTGRES_PASSWORD
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

POSTGRES_USER=async
POSTGRES_PASSWORD=CHANGE_ME_to_a_long_random_secret
POSTGRES_DB=async

# ── Admin bootstrap (only used by `npm run create-admin`) ────────────────────
# Creates/updates the first /admin account. Run once after `up -d`:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod \
#     run --rm migrate npm run create-admin
ADMIN_EMAIL=you@asyncs.tech
ADMIN_PASSWORD=CHANGE_ME_admin_password_min_8_chars
ADMIN_NAME=Admin
