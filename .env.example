# Postgres on your VPS — connection string used by Drizzle and the app.
# Example: postgres://USER:PASSWORD@your-vps-host:5432/async
# For a remote VPS, make sure Postgres listens on the public/VPN interface
# (listen_addresses in postgresql.conf) and pg_hba.conf allows the app host.
# Add ?sslmode=require if your VPS enforces TLS.
DATABASE_URL="postgres://async:change_me@127.0.0.1:5432/async"
