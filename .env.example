# ─────────────────────────────────────────────────────────────
# Cách 1 (DEV nhanh nhất) — Postgres bằng Docker, đã cấu hình sẵn:
#   docker compose up -d
#   npm run db:migrate
# DATABASE_URL tương ứng (container async_postgres, cổng 5434):
DATABASE_URL="postgres://async:async_dev_2026@127.0.0.1:5434/async"

# ─────────────────────────────────────────────────────────────
# Cách 2 (PRODUCTION) — Postgres trên VPS:
#   postgres://USER:PASSWORD@your-vps-host:5432/async?sslmode=require
# Lưu ý cho VPS từ xa:
#   - postgresql.conf: listen_addresses cho interface phù hợp (public/VPN)
#   - pg_hba.conf: cho phép host của app kết nối
#   - mở cổng 5432 CHỈ cho IP tin cậy; nên dùng TLS (?sslmode=require)
# DATABASE_URL="postgres://async:change_me@your-vps-host:5432/async?sslmode=require"
